# =============================================================================
# Email Backend Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment
# =============================================================================

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# Email provider: 'smtp' or 'mock'
# Use 'mock' for development (emails will be logged to console)
EMAIL_PROVIDER=smtp

# Email sender information
EMAIL_FROM=noreply@email.woragis.me
EMAIL_FROM_NAME="Jazz Melodic Email Service"

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# SMTP Configuration (required when EMAIL_PROVIDER=smtp)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=noreply@mail.woragis.me
SMTP_PASSWORD=your-smtp-password-here
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Server host and port
HOST=0.0.0.0
PORT=8080

# -----------------------------------------------------------------------------
# Database Configuration (optional - for storing email records)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgres://username:password@localhost:5432/email_backend

# -----------------------------------------------------------------------------
# Webhook Configuration (optional)
# -----------------------------------------------------------------------------
# WEBHOOK_SECRET=your-webhook-secret-here
# WEBHOOK_URL=https://your-domain.com/webhook
